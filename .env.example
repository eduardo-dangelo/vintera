# Vintera environment variables
# Copy to .env and fill in values: cp .env.example .env

# --- Required (local dev) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
DATABASE_URL=postgresql://postgres@localhost:5432/postgres

# --- App URL (optional locally; set for production) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Sentry (optional; set NEXT_PUBLIC_SENTRY_DISABLED=true to skip) ---
NEXT_PUBLIC_SENTRY_DISABLED=true
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORGANIZATION=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# --- Vercel Blob (optional; dev uses /public/uploads) ---
# BLOB_READ_WRITE_TOKEN=

# --- Cron (required on Vercel production) ---
# CRON_SECRET=

# --- Arcjet (optional) ---
# ARCJET_KEY=

# --- PostHog (optional) ---
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# --- Better Stack (optional) ---
# NEXT_PUBLIC_BETTER_STACK_SOURCE_TOKEN=
# NEXT_PUBLIC_BETTER_STACK_INGESTING_HOST=

# --- UK vehicle APIs (optional) ---
# DVLA_VES_API_URL=
# DVLA_VES_API_KEY=
# MOT_HISTORY_TOKEN_URL=
# MOT_HISTORY_SCOPE=
# MOT_HISTORY_CLIENT_ID=
# MOT_HISTORY_CLIENT_SECRET=
# MOT_HISTORY_API_KEY=
# MOT_HISTORY_VEHICLE_URL=

# --- Checkly (optional; workflow commented out) ---
# CHECKLY_EMAIL_ADDRESS=
# CHECKLY_PROJECT_NAME=vintera
# CHECKLY_LOGICAL_ID=vintera
# CHECKLY_REPO_URL=https://github.com/eduardo-dangelo/vintera
